APP_ENV=development

PATHS__PROJECT_ROOT=.
PATHS__DATA_DIR=data
PATHS__RESULTS_DIR=results
PATHS__REPORTS_DIR=reports
PATHS__PROMPT_DIR=config/prompts
PATHS__GOLDEN_SET_DIR=data/golden_sets
PATHS__BASELINE_DIR=data/baselines
PATHS__SHADOW_DB_PATH=data/shadow_log.db
PATHS__PHASE1_BENCHMARK_CSV=results/phase1_benchmark.csv
PATHS__PHASE1_SUMMARY_MD=results/phase1_summary.md
PATHS__PHASE2_BENCHMARK_MANIFEST=data/phase2_benchmark_manifest.json
PATHS__PHASE2_BENCHMARK_CSV=results/phase2_speech_benchmark.csv
PATHS__PHASE2_SUMMARY_MD=results/phase2_summary.md
PATHS__SPEECH_OUTPUT_DIR=results/speech
PATHS__REGRESSION_BASELINE_PATH=data/baselines/regression_baseline.json
PATHS__RAG_DOCS_DIR=data/rag_docs

LOGGING__LEVEL=INFO
LOGGING__JSON=true

VLLM__HOST=0.0.0.0
VLLM__PORT=8000
VLLM__BASE_URL=http://127.0.0.1:8000/v1
VLLM__MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int4
VLLM__QUANTIZATION=gptq
VLLM__DTYPE=float16
VLLM__GPU_MEMORY_UTILIZATION=0.99
VLLM__MAX_MODEL_LEN=1024
VLLM__MAX_NUM_BATCHED_TOKENS=512
VLLM__KV_CACHE_DTYPE=auto
VLLM__CPU_OFFLOAD_GB=0.0
VLLM__BENCHMARK_TIMEOUT_SEC=120
VLLM__HEALTH_TIMEOUT_SEC=180
VLLM__SWEEP_BATCHED_TOKENS=[512,1024,2048]
VLLM__SWEEP_CONCURRENCY=[1,4,8]
VLLM__SWEEP_GPU_MEMORY_UTILIZATION=[0.80,0.85,0.90]
VLLM__WINNING_MAX_NUM_BATCHED_TOKENS=512
VLLM__WINNING_CONCURRENT_REQUESTS=4
VLLM__WINNING_GPU_MEMORY_UTILIZATION=0.99
VLLM__WINNING_QUANTIZATION=gptq
VLLM__WINNING_DTYPE=float16
VLLM__CPU_REFERENCE_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM__CPU_REFERENCE_DEVICE=cpu
VLLM__CPU_REFERENCE_DTYPE=float32
VLLM__ENABLE_CPU_REFERENCE=false
VLLM__EVAL_MAX_TOKENS=160
VLLM__WARMUP_PROMPTS=2
VLLM__PROMPT_SAMPLE_SIZE=20

MLFLOW__TRACKING_URI=file:./mlruns
MLFLOW__EXPERIMENT_NAME=gptq-llm-project

EVAL__JUDGE_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int4
EVAL__JUDGE_TEMPERATURE=0.0
EVAL__JUDGE_TIMEOUT_SEC=60.0
EVAL__JUDGE_MAX_TOKENS=256
EVAL__BERTSCORE_MODEL_TYPE=distilbert-base-uncased
EVAL__SHADOW_SAMPLE_RATE=0.10
EVAL__SHADOW_TABLE_NAME=shadow_evaluations
EVAL__RAG_COLLECTION_NAME=phase3_rag_docs
EVAL__RAG_TOP_K=3
EVAL__RAG_REBUILD_INDEX=false

PROMETHEUS__PORT=9090

THRESHOLDS__ROUGE_MIN=0.35
THRESHOLDS__JUDGE_MIN=3.8
THRESHOLDS__HALLUCINATION_MAX_RATE=0.05
THRESHOLDS__DRIFT_ALERT_DELTA=0.05
THRESHOLDS__REQUEST_TIMEOUT_SEC=5.0
THRESHOLDS__ROUGE_DROP_TOLERANCE=0.10

VAD__THRESHOLD=0.50
VAD__MIN_SILENCE_MS=250
VAD__ENERGY_GATE_DB=-40.0
VAD__SAMPLING_RATE=16000
VAD__MIN_SPEECH_DURATION_MS=100
VAD__SPEECH_PAD_MS=30

ASR__MODEL_SIZE=medium
ASR__DEVICE=cuda
ASR__COMPUTE_TYPE=float16
ASR__LANGUAGE=en
ASR__BEAM_SIZE=5
ASR__BATCH_SIZE=8
ASR__BENCHMARK_MODEL_SIZES=medium,large-v3

DIARIZATION__MODEL_NAME=pyannote/speaker-diarization-3.1
DIARIZATION__HF_TOKEN=
DIARIZATION__MIN_SPEAKERS=
DIARIZATION__MAX_SPEAKERS=

TTS__MODEL_NAME=kokoro
TTS__VOICE=af_bella
TTS__STREAM_CHUNK_SIZE=1024
TTS__LANG_CODE=a
TTS__SPEED=1.0
TTS__SAMPLE_RATE=24000

ROUTING__PRIMARY_MODEL_ALIAS=qwen-gptq
ROUTING__SECONDARY_MODEL_ALIAS=qwen-gptq-safe
ROUTING__CACHE_TTL_SEC=300
ROUTING__STRICT_LATENCY_SLA_MS=2000

RAG__EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG__CHROMA_PERSIST_DIR=data/chroma
